@model прпгр.AnalyticsViewModel
@{
    ViewData["Title"] = "Аналитика";
}

<section class="py-5">
    <div class="container">
        <div class="row align-items-center mb-5">
            <div class="col-md-7">
                <h1 class="display-4 fw-bold mb-3">
                    Учебные материалы нового уровня
                </h1>
                <p class="lead mb-4">
                    Ищите, загружайте и оценивайте материалы, зарабатывайте баллы и открывайте премиум‑контент.
                </p>
                <a asp-controller="Materials" asp-action="All" class="btn btn-primary btn-lg me-2">
                    Найти материал
                </a>
                <a asp-controller="Materials" asp-action="Create" class="btn btn-outline-light btn-lg">
                    Загрузить свой
                </a>
            </div>

            <div class="col-md-5">
                <div class="card p-4">
                    <h5 class="mb-3">Ваша статистика</h5>
                    <p class="mb-1">Загружено материалов: <strong>@Model.MaterialsCount</strong></p>
                    <p class="mb-1">Баллы: <strong>@Model.Balance</strong></p>
                    <p class="mb-0">Премиум‑просмотров: <strong>@Model.PremiumViewsCount</strong></p>
                </div>
            </div>
        </div>

        <div class="row mb-5">
            <div class="col-md-6 mb-4">
                <div class="card shadow-sm">
                    <div class="card-body">
                        <h5 class="card-title">Загруженные материалы по месяцам</h5>
                        <canvas id="materialsChart"></canvas>
                    </div>
                </div>
            </div>
            <div class="col-md-6 mb-4">
                <div class="card shadow-sm">
                    <div class="card-body">
                        <h5 class="card-title">Баллы во времени</h5>
                        <canvas id="pointsChart"></canvas>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        const materialsCtx = document.getElementById('materialsChart').getContext('2d');
        const pointsCtx = document.getElementById('pointsChart').getContext('2d');

        const materialsChart = new Chart(materialsCtx, {
            type: 'bar',
            data: {
                labels: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.MaterialsPerMonthLabels)),
                datasets: [{
                    label: 'Материалы',
                    data: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.MaterialsPerMonthValues)),
                    backgroundColor: 'rgba(54, 162, 235, 0.7)'
                }]
            },
            options: {
                responsive: true,
                plugins: {
                    legend: { display: false }
                }
            }
        });

        const pointsChart = new Chart(pointsCtx, {
            type: 'line',
            data: {
                labels: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.PointsHistoryLabels)),
                datasets: [{
                    label: 'Баллы',
                    data: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.PointsHistoryValues)),
                    fill: false,
                    borderColor: 'rgba(255, 99, 132, 0.9)',
                    tension: 0.2
                }]
            },
            options: {
                responsive: true
            }
        });
    </script>
}
