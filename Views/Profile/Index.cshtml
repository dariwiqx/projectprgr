@{
    ViewData["Title"] = "Профиль";
    var user = (прпгр.Models.AppUser)ViewBag.User;
}

<div class="row mb-4">
    <div class="col-md-8 mx-auto">
        <div class="card bg-dark text-light border-secondary">
            <div class="card-body">
                <h3 class="card-title mb-4">&#x1F464; Профиль пользователя</h3>

                <table class="table table-dark table-bordered">
                    <tbody>
                        <tr>
                            <th style="width:40%;">Логин</th>
                            <td>@user.UserName</td>
                        </tr>
                        <tr>
                            <th>Роль</th>
                            <td>
                                @switch (user.Role)
                                {
                                    case "Admin":
                                        <span class="badge bg-danger">Администратор</span>
                                        break;
                                    case "Moderator":
                                        <span class="badge bg-warning text-dark">Модератор</span>
                                        break;
                                    default:
                                        <span class="badge bg-info">Студент</span>
                                        break;
                                }
                            </td>
                        </tr>
                        <tr>
                            <th>Баланс</th>
                            <td><strong>@user.Balance</strong> баллов</td>
                        </tr>
                        <tr>
                            <th>Статус</th>
                            <td>
                                @if (user.IsBlocked)
                                {
                                    <span class="badge bg-danger">Заблокирован</span>
                                }
                                else
                                {
                                    <span class="badge bg-success">Активен</span>
                                }
                            </td>
                        </tr>
                        <tr>
                            <th>Дата регистрации</th>
                            <td>@user.CreatedAt.ToString("dd.MM.yyyy HH:mm")</td>
                        </tr>
                    </tbody>
                </table>

                <h5 class="mt-4 mb-3">Статистика</h5>
                <div class="row text-center">
                    <div class="col-md-4 mb-3">
                        <div class="card bg-secondary text-light">
                            <div class="card-body">
                                <h4>@ViewBag.MaterialsCount</h4>
                                <small>Всего материалов</small>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4 mb-3">
                        <div class="card bg-secondary text-light">
                            <div class="card-body">
                                <h4>@ViewBag.ApprovedCount</h4>
                                <small>Одобренных</small>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4 mb-3">
                        <div class="card bg-secondary text-light">
                            <div class="card-body">
                                <h4>@ViewBag.PendingCount</h4>
                                <small>На модерации</small>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4 mb-3">
                        <div class="card bg-secondary text-light">
                            <div class="card-body">
                                <h4>@ViewBag.TotalDownloads</h4>
                                <small>Скачиваний</small>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4 mb-3">
                        <div class="card bg-secondary text-light">
                            <div class="card-body">
                                <h4>@ViewBag.TotalRatings</h4>
                                <small>Оценок получено</small>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4 mb-3">
                        <div class="card bg-secondary text-light">
                            <div class="card-body">
                                <h4>@(((double)ViewBag.AverageRating).ToString("0.0"))</h4>
                                <small>Средняя оценка</small>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="mt-3">
                    <a asp-controller="Materials" asp-action="My" class="btn btn-outline-light me-2">Мои материалы</a>
                    <a asp-controller="Analytics" asp-action="Index" class="btn btn-outline-light me-2">Аналитика</a>
                    <a asp-controller="Account" asp-action="Transactions" class="btn btn-outline-light">История баллов</a>
                </div>
            </div>
        </div>
    </div>
</div>
