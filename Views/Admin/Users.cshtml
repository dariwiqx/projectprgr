@model IEnumerable<прпгр.Models.AppUser>

@{
    ViewData["Title"] = "Управление пользователями";
}

<h2 class="mb-4">Управление пользователями</h2>

@if (TempData["AdminSuccess"] != null)
{
    <div class="alert alert-success">@TempData["AdminSuccess"]</div>
}
@if (TempData["AdminError"] != null)
{
    <div class="alert alert-danger">@TempData["AdminError"]</div>
}

<div class="d-flex gap-2 mb-4">
    <a asp-action="Settings" class="btn btn-outline-light">Настройки системы</a>
</div>

<div class="table-responsive">
    <table class="table table-dark-custom align-middle">
        <thead>
            <tr>
                <th>ID</th>
                <th>Логин</th>
                <th>Роль</th>
                <th>Баланс</th>
                <th>Статус</th>
                <th>Действия</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in Model)
            {
                var roleBadge = user.Role switch
                {
                    "Admin" => "bg-danger",
                    "Moderator" => "bg-info",
                    _ => "bg-secondary"
                };

                <tr>
                    <td>@user.Id</td>
                    <td>@user.UserName</td>
                    <td><span class="badge @roleBadge">@user.Role</span></td>
                    <td>@user.Balance</td>
                    <td>
                        @if (user.IsBlocked)
                        {
                            <span class="badge bg-danger">Заблокирован</span>
                        }
                        else
                        {
                            <span class="badge bg-success">Активен</span>
                        }
                    </td>
                    <td>
                        <div class="d-flex flex-wrap gap-1">
                            <form asp-action="ChangeRole" method="post" class="d-inline">
                                <input type="hidden" name="userId" value="@user.Id" />
                                <select name="role" class="form-select form-select-sm d-inline-block" style="width:auto;" onchange="this.form.submit()">
                                    <option value="Student" selected="@(user.Role == "Student")">Student</option>
                                    <option value="Moderator" selected="@(user.Role == "Moderator")">Moderator</option>
                                    <option value="Admin" selected="@(user.Role == "Admin")">Admin</option>
                                </select>
                            </form>

                            @if (user.IsBlocked)
                            {
                                <form asp-action="UnblockUser" method="post" class="d-inline">
                                    <input type="hidden" name="userId" value="@user.Id" />
                                    <button type="submit" class="btn btn-success btn-sm">Разблокировать</button>
                                </form>
                            }
                            else
                            {
                                <form asp-action="BlockUser" method="post" class="d-inline">
                                    <input type="hidden" name="userId" value="@user.Id" />
                                    <button type="submit" class="btn btn-danger btn-sm">Заблокировать</button>
                                </form>
                            }
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
