@model IEnumerable<прпгр.MaterialViewModel>

@{
    ViewData["Title"] = "Рекомендации";
}

<h2 class="mb-4">Рекомендованные материалы</h2>
<p class="text-muted mb-4">На основе ваших просмотров и оценок мы подобрали для вас материалы, которые могут быть полезны.</p>

@if (!Model.Any())
{
    <div class="alert alert-info">
        Пока недостаточно данных для персональных рекомендаций. Просмотрите и оцените несколько материалов, чтобы система могла подобрать релевантные предложения.
    </div>
    <a asp-controller="Materials" asp-action="All" class="btn btn-primary">Перейти к материалам</a>
}
else
{
    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4 pb-5">
        @foreach (var m in Model)
        {
            <div class="col">
                <div class="card h-100 shadow-sm border-0 card-hover">
                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title mb-1">
                            @m.Title
                            @if (m.IsPremium)
                            {
                                <span class="badge-premium ms-2">Премиум</span>
                            }
                        </h5>

                        <p class="card-text text-muted mb-1">
                            @m.Subject &bull; @m.Course @(string.IsNullOrEmpty(m.Topic) ? "" : " &bull; " + m.Topic)
                        </p>

                        @if (m.Tags != null && m.Tags.Any())
                        {
                            <div class="mb-2">
                                @foreach (var tag in m.Tags)
                                {
                                    <span class="badge bg-secondary me-1">@tag</span>
                                }
                            </div>
                        }

                        <p class="card-text flex-grow-1">@m.ShortDescription</p>

                        <div class="star-rating mb-2">
                            @for (int i = 1; i <= 5; i++)
                            {
                                @(i <= Math.Round(m.AverageRating) ? "★" : "☆")
                            }
                            <span class="text-muted ms-1">(@m.RatingsCount)</span>
                        </div>

                        <a asp-controller="Materials" asp-action="Details" asp-route-id="@m.Id" class="btn btn-outline-primary w-100">
                            Открыть
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
}
