@model IEnumerable<прпгр.Services.LmsCourse>

@{
    ViewData["Title"] = "Курсы LMS";
    var linkId = (int)ViewBag.LinkId;
    var lmsType = ViewBag.LmsType as string;
    var materials = ViewBag.Materials as List<прпгр.Models.Material> ?? new List<прпгр.Models.Material>();
}

<h2 class="mb-4">Курсы — @lmsType</h2>

@if (TempData["LmsSuccess"] != null)
{
    <div class="alert alert-success">@TempData["LmsSuccess"]</div>
}
@if (TempData["LmsError"] != null)
{
    <div class="alert alert-danger">@TempData["LmsError"]</div>
}

<a asp-action="Index" class="btn btn-outline-light mb-4">Назад к аккаунтам</a>

@if (!Model.Any())
{
    <div class="alert alert-info">Курсы не найдены.</div>
}
else
{
    <div class="row row-cols-1 row-cols-md-2 g-4">
        @foreach (var course in Model)
        {
            <div class="col">
                <div class="card h-100">
                    <div class="card-body">
                        <h5 class="card-title">@course.Name</h5>
                        <p class="text-muted small">@course.Description</p>
                        <p class="text-muted small">ID: @course.Id</p>

                        @if (materials.Any())
                        {
                            <form asp-action="Publish" method="post" class="mt-2">
                                <input type="hidden" name="linkId" value="@linkId" />
                                <input type="hidden" name="courseId" value="@course.Id" />
                                <div class="mb-2">
                                    <select name="materialId" class="form-select form-control" required>
                                        <option value="">Выберите материал...</option>
                                        @foreach (var m in materials)
                                        {
                                            <option value="@m.Id">@m.Title</option>
                                        }
                                    </select>
                                </div>
                                <button type="submit" class="btn btn-primary btn-sm">Опубликовать</button>
                            </form>
                        }
                        else
                        {
                            <p class="text-muted small">У вас нет одобренных материалов для публикации.</p>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
}
