@model прпгр.Controllers.LmsLinkViewModel

@{
    ViewData["Title"] = "Привязать LMS";
}

<h2 class="mb-4">Привязать LMS-аккаунт</h2>

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card auth-card">
            <div class="card-body p-4">
                <form asp-action="Link" method="post">
                    <div asp-validation-summary="All" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label class="form-label">Тип LMS</label>
                        <select name="LmsType" class="form-select form-control">
                            <option value="Moodle">Moodle</option>
                            <option value="Blackboard">Blackboard</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">URL сервера LMS</label>
                        <input type="url" name="LmsUrl" class="form-control" placeholder="https://moodle.university.edu" value="@Model.LmsUrl" required />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">API-токен</label>
                        <input type="text" name="LmsToken" class="form-control" placeholder="Токен авторизации" value="@Model.LmsToken" required />
                        <div class="form-text text-muted">Получите токен в настройках вашего LMS-аккаунта</div>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">Привязать</button>
                        <a asp-action="Index" class="btn btn-outline-light">Отмена</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
