@model прпгр.Models.HomeDashboardViewModel
@{
    ViewData["Title"] = "Главная";
}

<section class="py-5">
    <div class="container">
        <div class="row align-items-center mb-5">
            <div class="col-md-7">
                <h1 class="display-4 fw-bold mb-3">
                    Учебные материалы нового уровня
                </h1>
                <p class="lead mb-4">
                    Ищите, загружайте и оценивайте материалы, зарабатывайте баллы и открывайте премиум-контент.
                </p>
                <a asp-controller="Materials" asp-action="All" class="btn btn-primary btn-lg me-2">
                    Найти материал
                </a>
                <a asp-controller="Materials" asp-action="Create" class="btn btn-outline-light btn-lg">
                    Загрузить свой
                </a>
            </div>

            <div class="col-md-5">
                <div class="card p-4">
                    <h5 class="mb-3">Статистика</h5>
                    <p class="mb-1">Всего материалов: <strong>@Model.TotalMaterials</strong></p>
                    <p class="mb-1">Одобренных: <strong>@Model.ApprovedMaterials</strong></p>
                    <p class="mb-1">Премиум-просмотров: <strong>@Model.PremiumViewsCount</strong></p>
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <hr />
                        <p class="mb-1">Моих материалов: <strong>@Model.MyMaterialsCount</strong></p>
                        <p class="mb-1">Моих премиум-просмотров: <strong>@Model.MyPremiumViewsCount</strong></p>
                        <p class="mb-0">Мой баланс: <strong>@Model.CurrentUserBalance</strong> баллов</p>
                    }
                </div>
            </div>
        </div>

        <div class="row align-items-start">
            <div class="col-md-8">
                <h2 class="mb-3">Найти учебный материал</h2>

                <div class="card mb-4">
                    <div class="card-body">
                        <form method="get" asp-controller="Materials" asp-action="All">
                            <div class="mb-3">
                                <label for="query" class="form-label">Поисковый запрос</label>
                                <input type="text" class="form-control" id="query" name="query"
                                       placeholder="Например, лабораторная по физике" />
                            </div>

                            <div class="row">
                                <div class="col-md-4 mb-3">
                                    <label class="form-label" for="subject">Предмет</label>
                                    <input type="text" class="form-control" id="subject" name="subject" />
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label class="form-label" for="course">Курс</label>
                                    <input type="text" class="form-control" id="course" name="course" />
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label class="form-label" for="topic">Тема</label>
                                    <input type="text" class="form-control" id="topic" name="topic" />
                                </div>
                            </div>

                            <div class="d-flex align-items-center gap-3 mb-3">
                                <div class="form-check form-check-inline">
                                    <input class="form-check-input" type="radio" name="mode" id="modeKeyword" value="keyword" checked>
                                    <label class="form-check-label" for="modeKeyword">По ключевым словам</label>
                                </div>
                                <div class="form-check form-check-inline">
                                    <input class="form-check-input" type="radio" name="mode" id="modeSemantic" value="semantic">
                                    <label class="form-check-label" for="modeSemantic">Семантический</label>
                                </div>
                                <div class="form-check form-check-inline">
                                    <input type="checkbox" class="form-check-input" id="onlyPremium" name="onlyPremium" />
                                    <label class="form-check-label" for="onlyPremium">Только премиум</label>
                                </div>
                            </div>

                            <button type="submit" class="btn btn-primary">Найти</button>
                        </form>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <h3 class="mb-3">Рекомендации</h3>
                @if (Model.RecommendedMaterials.Any())
                {
                    @foreach (var m in Model.RecommendedMaterials)
                    {
                        <div class="card mb-3 card-hover">
                            <div class="card-body py-3">
                                <h6 class="mb-1">
                                    @m.Title
                                    @if (m.IsPremium)
                                    {
                                        <span class="badge-premium ms-1" style="font-size:0.65rem;">P</span>
                                    }
                                </h6>
                                <p class="text-muted small mb-1">@m.Subject &bull; @m.Course</p>
                                <div class="star-rating small mb-1">
                                    @for (int i = 1; i <= 5; i++)
                                    {
                                        @(i <= Math.Round(m.AverageRating) ? "★" : "☆")
                                    }
                                    <span class="text-muted">(@m.RatingsCount)</span>
                                </div>
                                <a asp-controller="Materials" asp-action="Details" asp-route-id="@m.Id" class="btn btn-outline-primary btn-sm w-100">Открыть</a>
                            </div>
                        </div>
                    }
                    <a asp-controller="Recommendations" asp-action="Index" class="btn btn-outline-light btn-sm w-100">Все рекомендации</a>
                }
                else if (User.Identity?.IsAuthenticated == true)
                {
                    <div class="card">
                        <div class="card-body">
                            <p class="text-muted small mb-0">Просматривайте и оценивайте материалы, чтобы получить персональные рекомендации.</p>
                        </div>
                    </div>
                }
                else
                {
                    <div class="card">
                        <div class="card-body">
                            <p class="text-muted small mb-0">Войдите в систему, чтобы получить персональные рекомендации.</p>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</section>
