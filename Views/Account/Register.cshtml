@model прпгр.Models.RegisterViewModel

@{
    ViewData["Title"] = "Регистрация";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-5">
        <div class="card auth-card">
            <div class="card-body p-4">
                <h2 class="text-center mb-4">Регистрация</h2>

                <form asp-action="Register" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="UserName" class="form-label">Логин</label>
                        <input asp-for="UserName" class="form-control" placeholder="Придумайте логин" />
                        <span asp-validation-for="UserName" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Password" class="form-label">Пароль</label>
                        <input asp-for="Password" class="form-control" type="password" placeholder="Придумайте пароль" />
                        <span asp-validation-for="Password" class="text-danger"></span>
                    </div>

                    <button type="submit" class="btn btn-primary w-100 mb-3">Зарегистрироваться</button>

                    <p class="text-center text-muted mb-0">
                        Уже есть аккаунт? <a asp-action="Login">Войти</a>
                    </p>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
