@model прпгр.Models.MaterialDetailsViewModel

@{
    ViewData["Title"] = Model.Title;
}

<div class="row g-4">
    <div class="col-md-8">
        <div class="card mb-4">
            <div class="card-body">
                <h2 class="mb-2">@Model.Title</h2>

                @if (Model.IsPremium)
                {
                    <span class="badge-premium mb-3">Премиум</span>
                }

                <p class="mb-2">
                    @switch (Model.Status)
                    {
                        case "Pending":
                            @:<span class="badge bg-secondary">На модерации</span>
                            break;
                        case "Approved":
                            @:<span class="badge bg-success">Одобрен</span>
                            break;
                        case "Rejected":
                            @:<span class="badge bg-warning text-dark">Отклонён</span>
                            break;
                        case "Blocked":
                            @:<span class="badge bg-danger">Заблокирован</span>
                            break;
                    }
                </p>

                <hr />

                <div class="mb-3">
                    @if (!string.IsNullOrEmpty(Model.Description))
                    {
                        <p>@Model.Description</p>
                    }
                    else
                    {
                        <p class="text-muted">Описание отсутствует.</p>
                    }
                </div>

                @if (TempData["PremiumError"] != null)
                {
                    <div class="alert alert-danger">@TempData["PremiumError"]</div>
                }
                @if (TempData["PremiumInfo"] != null)
                {
                    <div class="alert alert-info">@TempData["PremiumInfo"]</div>
                }

                <a class="btn btn-primary mb-3" asp-action="Open" asp-route-id="@Model.Id">
                    Открыть файл
                </a>
            </div>
        </div>

        <div class="card mb-4">
            <div class="card-body">
                <h4 class="mb-3">Оценки и отзывы</h4>

                @if (TempData["RatingError"] != null)
                {
                    <div class="alert alert-warning">@TempData["RatingError"]</div>
                }
                @if (TempData["RatingInfo"] != null)
                {
                    <div class="alert alert-info">@TempData["RatingInfo"]</div>
                }

                @if (User.Identity?.IsAuthenticated == true)
                {
                    <form asp-action="Rate" asp-route-id="@Model.Id" method="post" class="mb-4">
                        <div class="mb-3">
                            <label class="form-label">Ваша оценка (1–5)</label>
                            <input type="number" name="score" min="1" max="5" class="form-control" required style="max-width:100px;" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Комментарий (необязательно)</label>
                            <textarea name="comment" class="form-control" rows="3" maxlength="1000"></textarea>
                        </div>
                        <button type="submit" class="btn btn-success">Оценить</button>
                    </form>
                }
                else
                {
                    <div class="alert alert-info">Войдите в систему, чтобы оставить оценку.</div>
                }

                @if (!Model.Ratings.Any())
                {
                    <p class="text-muted">Отзывов пока нет.</p>
                }
                else
                {
                    @foreach (var r in Model.Ratings)
                    {
                        <div class="card mb-2">
                            <div class="card-body py-2 px-3">
                                <div class="d-flex justify-content-between align-items-center">
                                    <div class="star-rating">
                                        @for (int i = 1; i <= 5; i++)
                                        {
                                            @(i <= r.Score ? "★" : "☆")
                                        }
                                    </div>
                                    <small class="text-muted">@r.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</small>
                                </div>
                                @if (!string.IsNullOrEmpty(r.Comment))
                                {
                                    <p class="mb-0 mt-1">@r.Comment</p>
                                }
                            </div>
                        </div>
                    }
                }
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card mb-4">
            <div class="card-body">
                <h5 class="mb-3">Информация</h5>

                <p class="mb-1"><strong>Предмет:</strong> @Model.Subject</p>
                <p class="mb-1"><strong>Курс:</strong> @Model.Course</p>
                @if (!string.IsNullOrEmpty(Model.Topic))
                {
                    <p class="mb-1"><strong>Тема:</strong> @Model.Topic</p>
                }

                <hr />

                <div class="star-rating mb-2" style="font-size:1.2rem;">
                    @for (int i = 1; i <= 5; i++)
                    {
                        @(i <= Math.Round(Model.AverageRating) ? "★" : "☆")
                    }
                </div>
                <p class="mb-1">@Model.AverageRating.ToString("0.0") из 5 (@Model.RatingsCount оценок)</p>

                @if (Model.Tags.Any())
                {
                    <hr />
                    <div>
                        @foreach (var tag in Model.Tags)
                        {
                            <span class="badge bg-secondary me-1 mb-1">@tag</span>
                        }
                    </div>
                }
            </div>
        </div>

        @if (User.Identity?.IsAuthenticated == true)
        {
            <div class="card mb-4">
                <div class="card-body">
                    <h5 class="mb-3">Пожаловаться</h5>

                    @if (TempData["ComplaintError"] != null)
                    {
                        <div class="alert alert-warning small">@TempData["ComplaintError"]</div>
                    }
                    @if (TempData["ComplaintSuccess"] != null)
                    {
                        <div class="alert alert-success small">@TempData["ComplaintSuccess"]</div>
                    }

                    <form asp-controller="Complaints" asp-action="Create" method="post">
                        <input type="hidden" name="materialId" value="@Model.Id" />
                        <div class="mb-2">
                            <textarea name="reason" class="form-control" rows="2" placeholder="Причина жалобы..." required></textarea>
                        </div>
                        <button type="submit" class="btn btn-outline-danger btn-sm w-100">Отправить жалобу</button>
                    </form>
                </div>
            </div>
        }
    </div>
</div>
